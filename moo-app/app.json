{
  "expo": {
    "name": "eMooJI",
    "slug": "emooji",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icons/icon-1024.png",
    "userInterfaceStyle": "dark",
    "scheme": "emooji",
    "splash": {
      "backgroundColor": "#080c10"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emooji.app",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "eMooJI uses your location to centre the map on your farm.",
        "NSLocationAlwaysUsageDescription": "eMooJI uses your location to centre the map on your farm."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#080c10"
      },
      "package": "com.emooji.app",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/icons/icon-192.png",
      "name": "eMooJI — Field Intelligence",
      "shortName": "eMooJI",
      "description": "Draw any field in Europe. Get real satellite insights instantly.",
      "themeColor": "#0bdb6e",
      "backgroundColor": "#080c10",
      "display": "standalone",
      "orientation": "any",
      "pwa": {
        "enabled": true
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#080c10",
          "image": "./assets/icons/icon-192.png",
          "resizeMode": "contain"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    }
  }
}