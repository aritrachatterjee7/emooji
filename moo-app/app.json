{
  "expo": {
    "name": "eMooJI",
    "slug": "emooji",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./public/icon-1024.png",
    "userInterfaceStyle": "dark",
    "scheme": "emooji",
    "splash": {
      "backgroundColor": "#07090e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.emooji.app",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_KEY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "eMooJI uses your location to centre the map on your farm.",
        "NSLocationAlwaysUsageDescription": "eMooJI uses your location to centre the map on your farm."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/adaptive-icon.png",
        "backgroundColor": "#07090e"
      },
      "package": "com.emooji.app",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_KEY"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./public/icon-192.png",
      "name": "eMooJI — Field Intelligence",
      "shortName": "eMooJI",
      "description": "Draw any field in Europe. Get real satellite insights instantly.",
      "themeColor": "#00e676",
      "backgroundColor": "#07090e",
      "display": "standalone",
      "orientation": "any",
      "meta": {
        "viewport": "width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07090e",
          "image": "./public/icon-192.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0a5a571b-5f13-4425-a47c-70236af57d81"
      }
    }
  }
}